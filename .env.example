# Voice AI Platform environment template
# Copy this file to .env (used by root scripts and root docker-compose).
# If you use backend/docker-compose.yml directly, copy the same values to backend/.env.local.

# ===========================
# LiveKit + VoBiz (Required)
# ===========================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxx
VOBIZ_SIP_DOMAIN=your-sip-domain.sip.vobiz.ai
LIVEKIT_SIP_URI=sip:your-project-id.sip.livekit.cloud
VOBIZ_AUTH_ID=your_vobiz_auth_id
VOBIZ_AUTH_TOKEN=your_vobiz_auth_token
VOBIZ_CALLER_ID=+91XXXXXXXXXX
VOBIZ_USERNAME=your_vobiz_username
VOBIZ_PASSWORD=your_vobiz_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
VOBIZ_INBOUND_NUMBER=+91XXXXXXXXXX
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
DEFAULT_OUTBOUND_TARGET=+91XXXXXXXXXX
AGENT_PERSONA_NAME=Shubhi
AGENT_COMPANY_NAME=Estate Company
AGENT_DEFAULT_LANGUAGE=hi
VOBIZ_TRUNK_NAME=Demo
OUTBOUND_FIRST_MESSAGE=Namaste, main Shubhi Estate Company se bol rahi hoon. Kya aap mujhe sun pa rahe hain?
NO_SPEECH_REPROMPT_SEC=7

# ===========================
# OpenAI (Required)
# ===========================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_REALTIME_VOICE=alloy
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=1.20
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_LANGUAGE=hi

# ===========================
# Voice Provider Options
# ===========================
TTS_PROVIDER=openai
STT_PROVIDER=openai
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
CARTESIA_API_KEY=
ASSEMBLYAI_API_KEY=
CARTESIA_TTS_MODEL=sonic-2
CARTESIA_TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02
ENABLE_NOISE_CANCELLATION=false
VAD_MIN_SPEECH_DURATION=0.04
VAD_MIN_SILENCE_DURATION=0.25
VAD_PREFIX_PADDING_DURATION=0.25
VAD_ACTIVATION_THRESHOLD=0.35
SESSION_MIN_INTERRUPTION_DURATION=0.15
SESSION_MIN_ENDPOINTING_DELAY=0.25
SESSION_MAX_ENDPOINTING_DELAY=0.90
SESSION_FALSE_INTERRUPTION_TIMEOUT=0.70
SESSION_PREEMPTIVE_GENERATION=true
TRANSFER_REQUIRE_CONFIRMATION=true
TRANSFER_CONFIRM_TIMEOUT_SEC=30

# ===========================
# Analytics / AI (Optional)
# ===========================
GOOGLE_API_KEY=

# ===========================
# Database + Cache (Required)
# ===========================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vobiz_calls
MONGODB_DB_NAME=vobiz_calls
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# ===========================
# API / Frontend
# ===========================
API_HOST=0.0.0.0
API_PORT=8000
VITE_API_URL=http://localhost:8000

# ===========================
# Authentication
# ===========================
AUTH_ENABLED=true
JWT_SECRET_KEY=change_this_to_a_long_random_value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_API_KEY=change_this_internal_api_key

# ===========================
# AWS S3 Recordings (Optional)
# ===========================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1
